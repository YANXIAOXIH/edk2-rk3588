#include "rk3588-orangepi-5-max.dts"

/ {
	model = "LemonPi Pi1";
	compatible = "lemonpi,rk3588-lemonpi-pi1", "rockchip,rk3588";

	fan: pwm-fan {
		compatible = "pwm-fan";
		#cooling-cells = <2>;
		pwms = <&pwm4 0 5000 0>;
		cooling-levels = <0 100 150 200 255>;
		rockchip,temp-trips = <
			50000	1
			55000	2
			60000	3
			65000	4
		>;
	};
};

&combphy0_ps { /* Mini-PCIe/SATA3.0-PCIe (x1) Combo PHY */
	status = "okay";
};

&pcie2x1l2 { /* Mini-PCIe (x1) */
	reset-gpios = <&gpio3 RK_PD1 GPIO_ACTIVE_HIGH>;
	disable-gpios = <&gpio3 RK_PC1 GPIO_ACTIVE_HIGH>;
	status = "disabled";
};

&sata0 { /* SATA3.0-PCIe (x1) */
	status = "okay";
};